            print(Legendrelist[i][j],"x^",j)

Coefficients = []
for i in range(len(Legendrelist)):
    val = listmultiply(fn,Legendrelist[i])
    newval = (innerproduct(val))*((2*i)+1)/2
    Coefficients.append(newval)

print("Legendre form of given eq is : ")
i = 0
